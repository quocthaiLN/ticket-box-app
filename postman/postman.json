    {
      "name": "7-MOMO. Simulate MOMO webhook (success)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Giả lập IPN MoMo. Chỉ chạy bước này (THAY cho bước 7) khi payment_provider = MOMO.",
              "// Chữ ký HMAC-SHA256 phải khớp verifyMomoSignature (payment.service.ts): secret + accessKey lấy từ ENV.",
              "const CryptoJS = require('crypto-js');",
              "const secret = pm.collectionVariables.get('momo_secret_key');",
              "const accessKey = pm.collectionVariables.get('momo_access_key');",
              "const partnerCode = pm.collectionVariables.get('momo_partner_code');",
              "const orderId = pm.collectionVariables.get('order_id');",
              "const total = pm.collectionVariables.get('total_amount');",
              "const amount = String(Math.round(parseFloat(total)));",
              "const requestId = orderId;",
              "const transId = String(Date.now());",
              "const responseTime = String(Date.now());",
              "const resultCode = '0';",
              "const message = 'Successful.';",
              "const orderInfo = 'Payment for order ' + orderId;",
              "const orderType = '';",
              "const payType = '';",
              "const extraData = '';",
              "",
              "// Thứ tự field PHẢI trùng verifyMomoSignature.",
              "const raw = [",
              "  `accessKey=${accessKey}`,",
              "  `amount=${amount}`,",
              "  `extraData=${extraData}`,",
              "  `message=${message}`,",
              "  `orderId=${orderId}`,",
              "  `orderInfo=${orderInfo}`,",
              "  `orderType=${orderType}`,",
              "  `partnerCode=${partnerCode}`,",
              "  `payType=${payType}`,",
              "  `requestId=${requestId}`,",
              "  `responseTime=${responseTime}`,",
              "  `resultCode=${resultCode}`,",
              "  `transId=${transId}`",
              "].join('&');",
              "const signature = CryptoJS.HmacSHA256(raw, secret).toString(CryptoJS.enc.Hex);",
              "",
              "pm.collectionVariables.set('momo_amount', amount);",
              "pm.collectionVariables.set('momo_trans_id', transId);",
              "pm.collectionVariables.set('momo_response_time', responseTime);",
              "pm.collectionVariables.set('momo_request_id', requestId);",
              "pm.collectionVariables.set('momo_order_info', orderInfo);",
              "pm.collectionVariables.set('momo_message', message);",
              "pm.collectionVariables.set('momo_signature', signature);",
              "console.log('momo raw =', raw);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('MoMo webhook accepted 200', () => pm.response.code === 200);",
              "const body = pm.response.json();",
              "pm.test('MoMo message success', () => body.message === 'success');",
              "if (pm.response.code !== 200) {",
              "  console.warn('MoMo webhook bị từ chối:', JSON.stringify(body), '-> kiểm tra MOMO_SECRET_KEY/MOMO_ACCESS_KEY khớp .env');",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
