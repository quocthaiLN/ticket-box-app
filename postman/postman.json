      "name": "6. Create payment (VNPAY)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const requested = pm.collectionVariables.get('payment_provider');",
              "if (pm.response.code === 201) {",
              "  const d = pm.response.json().data;",
              "  pm.collectionVariables.set('payment_id', d.payment_id);",
              "  pm.test('Status PENDING', () => d.status === 'PENDING');",
              "  // Backend KHÔNG còn fallback khi client chỉ định provider → phải đúng provider đã chọn.",
              "  pm.test('Provider khớp yêu cầu', () => d.provider === requested);",
              "  console.log('provider =', d.provider, '| checkout_url =', d.checkout_url);",
              "} else if (pm.response.code === 503) {",
              "  // Provider đã chọn lỗi (vd MoMo down). User chọn lại phương thức và POST lại bước 6.",
              "  const b = pm.response.json();",
              "  pm.test('Provider unavailable -> chon lai & POST lai', () => b.code === 'PAYMENT_PROVIDER_UNAVAILABLE');",
              "  console.warn('Thanh toan that bai:', b.detail);",
              "  console.warn('=> Doi bien collection payment_provider sang provider khac (vd VNPAY) roi Send lai buoc 6.');",
              "} else {",
              "  pm.test('Payment created 201 hoac 503', () => false);",
              "  console.warn('Response khong mong doi:', pm.response.code, pm.response.text());",
              "}"
            ]
          }
        }
