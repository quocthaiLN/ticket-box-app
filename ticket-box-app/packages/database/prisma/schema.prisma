generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  AUDIENCE
  ORGANIZER
  CHECKER
  ADMIN

  @@map("user_role")
}

enum UserStatus {
  ACTIVE
  LOCKED
  DISABLED

  @@map("user_status")
}

enum ConcertStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED

  @@map("concert_status")
}

enum TicketTypeStatus {
  DRAFT
  ON_SALE
  SOLD_OUT
  CLOSED

  @@map("ticket_type_status")
}

enum OrderStatus {
  HELD
  CONFIRMED
  CANCELLED
  EXPIRED

  @@map("order_status")
}

enum PaymentProvider {
  VNPAY
  MOMO

  @@map("payment_provider")
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
  REFUNDED

  @@map("payment_status")
}

enum TicketStatus {
  ISSUED
  CHECKED_IN
  CANCELLED
  REFUNDED

  @@map("ticket_status")
}

enum DeviceStatus {
  ACTIVE
  REVOKED
  LOST

  @@map("device_status")
}

enum CheckinResult {
  SUCCESS
  ALREADY_CHECKED_IN
  INVALID_TICKET
  INVALID_GUEST
  WRONG_CONCERT
  WRONG_GATE
  CONFLICT
  ERROR

  @@map("checkin_result")
}

enum OfflineBatchStatus {
  PENDING
  SYNCING
  DONE
  FAILED

  @@map("offline_batch_status")
}

enum OfflineItemStatus {
  PENDING
  ACCEPTED
  CONFLICT
  INVALID
  WRONG_GATE
  ERROR

  @@map("offline_item_status")
}

enum ImportStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
  PARTIAL

  @@map("import_status")
}

enum GuestStatus {
  INVITED
  CHECKED_IN
  CANCELLED

  @@map("guest_status")
}

enum ArtistBioJobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED

  @@map("artist_bio_job_status")
}

enum NotificationChannel {
  APP
  EMAIL
  SMS
  ZALO

  @@map("notification_channel")
}

enum NotificationType {
  SYSTEM
  ORDER_CONFIRMED
  PAYMENT_FAILED
  TICKET_ISSUED
  CONCERT_UPDATED
  CHECKIN_ALERT
  ARTIST_BIO_READY

  @@map("notification_type")
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED

  @@map("notification_status")
}

model User {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String     @unique @db.VarChar(255)
  passwordHash String     @map("password_hash")
  fullName     String     @map("full_name") @db.VarChar(255)
  phone        String?    @unique @db.VarChar(20)
  role         UserRole   @default(AUDIENCE)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @default(now()) @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")

  organizedConcerts     Concert[]               @relation("ConcertOrganizer")
  orders                Order[]
  tickets               Ticket[]
  checkedInTickets      Ticket[]                @relation("TicketCheckedInBy")
  checkinDevices        CheckinDevice[]         @relation("DeviceStaff")
  checkinLogs           CheckinLog[]            @relation("CheckinStaff")
  offlineBatches        OfflineCheckinBatch[]   @relation("OfflineBatchStaff")
  guestImportJobs       GuestImportJob[]        @relation("GuestImportCreator")
  checkedInGuests       GuestList[]             @relation("GuestCheckedInBy")
  artistBioJobs         ArtistBioJob[]          @relation("ArtistBioRequestedBy")
  notifications         Notification[]
  auditLogs             AuditLog[]              @relation("AuditActor")
  UserTicketTypeCounter UserTicketTypeCounter[]

  @@index([role])
  @@index([status])
  @@map("users")
}

model Venue {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(255)
  address   String
  city      String   @db.VarChar(100)
  capacity  Int?
  mapUrl    String?  @map("map_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  concerts Concert[]

  @@index([city])
  @@map("venues")
}

model Concert {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  venueId       String        @map("venue_id") @db.Uuid
  organizerId   String        @map("organizer_id") @db.Uuid
  title         String        @db.VarChar(255)
  slug          String        @unique @db.VarChar(255)
  description   String?
  artistName    String        @map("artist_name") @db.VarChar(255)
  artistBio     String?       @map("artist_bio")
  startsAt      DateTime      @map("starts_at")
  endsAt        DateTime      @map("ends_at")
  status        ConcertStatus @default(DRAFT)
  coverImageUrl String?       @map("cover_image_url")
  seatMapUrl    String?       @map("seat_map_url")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at")

  venue           Venue                 @relation(fields: [venueId], references: [id], onDelete: Restrict)
  organizer       User                  @relation("ConcertOrganizer", fields: [organizerId], references: [id], onDelete: Restrict)
  seatZones       SeatZone[]
  checkinGates    CheckinGate[]
  ticketTypes     TicketType[]
  orders          Order[]
  tickets         Ticket[]
  checkinDevices  CheckinDevice[]
  checkinLogs     CheckinLog[]
  offlineBatches  OfflineCheckinBatch[]
  guestImportJobs GuestImportJob[]
  guestList       GuestList[]
  artistBioJobs   ArtistBioJob[]
  notifications   Notification[]

  @@index([status, startsAt])
  @@index([venueId])
  @@index([organizerId, status])
  @@map("concerts")
}

model SeatZone {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  concertId   String   @map("concert_id") @db.Uuid
  code        String   @db.VarChar(50)
  name        String   @db.VarChar(100)
  description String?
  capacity    Int
  svgPath     String?  @map("svg_path")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  concert             Concert              @relation(fields: [concertId], references: [id], onDelete: Cascade)
  gateZones           CheckinGateZone[]
  ticketTypes         TicketType[]
  tickets             Ticket[]
  checkinLogs         CheckinLog[]
  offlineCheckinItems OfflineCheckinItem[]
  guestList           GuestList[]

  @@unique([concertId, code])
  @@unique([id, concertId])
  @@index([concertId, sortOrder])
  @@map("seat_zones")
}

model CheckinGate {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  concertId   String   @map("concert_id") @db.Uuid
  code        String   @db.VarChar(50)
  name        String   @db.VarChar(255)
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  concert             Concert               @relation(fields: [concertId], references: [id], onDelete: Cascade)
  gateZones           CheckinGateZone[]
  checkinDevices      CheckinDevice[]
  checkinLogs         CheckinLog[]
  offlineBatches      OfflineCheckinBatch[]
  offlineCheckinItems OfflineCheckinItem[]

  @@unique([concertId, code])
  @@unique([id, concertId])
  @@index([concertId, isActive])
  @@map("checkin_gates")
}

model CheckinGateZone {
  gateId     String   @map("gate_id") @db.Uuid
  seatZoneId String   @map("seat_zone_id") @db.Uuid
  concertId  String   @map("concert_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  gate     CheckinGate @relation(fields: [gateId, concertId], references: [id, concertId], onDelete: Cascade)
  seatZone SeatZone    @relation(fields: [seatZoneId, concertId], references: [id, concertId], onDelete: Cascade)

  @@id([gateId, seatZoneId])
  @@index([seatZoneId])
  @@index([concertId])
  @@map("checkin_gate_zones")
}

model TicketType {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  concertId     String           @map("concert_id") @db.Uuid
  seatZoneId    String           @map("seat_zone_id") @db.Uuid
  name          String           @db.VarChar(100)
  description   String?
  price         Decimal          @db.Decimal(12, 2)
  currency      String           @default("VND") @db.Char(3)
  totalQuantity Int              @map("total_quantity")
  heldQuantity  Int              @default(0) @map("held_quantity")
  soldQuantity  Int              @default(0) @map("sold_quantity")
  maxPerUser    Int              @map("max_per_user")
  saleStartAt   DateTime         @map("sale_start_at")
  saleEndAt     DateTime         @map("sale_end_at")
  status        TicketTypeStatus @default(DRAFT)
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @default(now()) @updatedAt @map("updated_at")

  concert    Concert                 @relation(fields: [concertId], references: [id], onDelete: Cascade)
  seatZone   SeatZone                @relation(fields: [seatZoneId, concertId], references: [id, concertId], onDelete: Restrict)
  counters   UserTicketTypeCounter[]
  orderItems OrderItem[]
  tickets    Ticket[]

  @@unique([concertId, name])
  @@unique([id, concertId])
  @@index([concertId, status])
  @@index([seatZoneId])
  @@index([saleStartAt, saleEndAt])
  @@map("ticket_types")
}

model UserTicketTypeCounter {
  userId       String   @map("user_id") @db.Uuid
  ticketTypeId String   @map("ticket_type_id") @db.Uuid
  heldQuantity Int      @default(0) @map("held_quantity")
  paidQuantity Int      @default(0) @map("paid_quantity")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)

  @@id([userId, ticketTypeId])
  @@index([ticketTypeId])
  @@map("user_ticket_type_counters")
}

model Order {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String      @map("user_id") @db.Uuid
  concertId       String      @map("concert_id") @db.Uuid
  idempotencyKey  String      @unique @map("idempotency_key") @db.VarChar(128)
  status          OrderStatus @default(HELD)
  totalAmount     Decimal     @default(0) @map("total_amount") @db.Decimal(12, 2)
  currency        String      @default("VND") @db.Char(3)
  holdExpiresAt   DateTime?   @map("hold_expires_at")
  confirmedAt     DateTime?   @map("confirmed_at")
  cancelledAt     DateTime?   @map("cancelled_at")
  expiredAt       DateTime?   @map("expired_at")
  cancelledReason String?     @map("cancelled_reason")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @default(now()) @updatedAt @map("updated_at")

  user     User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  concert  Concert     @relation(fields: [concertId], references: [id], onDelete: Restrict)
  items    OrderItem[]
  payments Payment[]
  tickets  Ticket[]

  @@index([userId, status, createdAt])
  @@index([concertId, status])
  @@index([holdExpiresAt])
  @@map("orders")
}

model OrderItem {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId      String   @map("order_id") @db.Uuid
  ticketTypeId String   @map("ticket_type_id") @db.Uuid
  quantity     Int
  unitPrice    Decimal  @map("unit_price") @db.Decimal(12, 2)
  lineTotal    Decimal  @map("line_total") @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @map("created_at")

  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Restrict)
  tickets    Ticket[]

  @@index([orderId])
  @@index([ticketTypeId])
  @@map("order_items")
}

model Payment {
  id                    String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId               String          @map("order_id") @db.Uuid
  provider              PaymentProvider
  providerTransactionId String?         @map("provider_transaction_id") @db.VarChar(255)
  idempotencyKey        String          @unique @map("idempotency_key") @db.VarChar(128)
  amount                Decimal         @db.Decimal(12, 2)
  currency              String          @default("VND") @db.Char(3)
  status                PaymentStatus   @default(PENDING)
  checkoutUrl           String?         @map("checkout_url")
  providerPayload       Json?           @map("provider_payload") @db.JsonB
  webhookPayload        Json?           @map("webhook_payload") @db.JsonB
  webhookReceivedAt     DateTime?       @map("webhook_received_at")
  webhookSignatureValid Boolean?        @map("webhook_signature_valid")
  paidAt                DateTime?       @map("paid_at")
  failureReason         String?         @map("failure_reason")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @default(now()) @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@unique([provider, providerTransactionId])
  @@index([orderId, status])
  @@index([status, createdAt])
  @@map("payments")
}

model Ticket {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId       String       @map("order_id") @db.Uuid
  orderItemId   String       @map("order_item_id") @db.Uuid
  userId        String       @map("user_id") @db.Uuid
  concertId     String       @map("concert_id") @db.Uuid
  ticketTypeId  String       @map("ticket_type_id") @db.Uuid
  seatZoneId    String       @map("seat_zone_id") @db.Uuid
  qrTokenHash   String       @unique @map("qr_token_hash") @db.VarChar(255)
  qrPayload     Json?        @map("qr_payload") @db.JsonB
  qrSignature   String?      @map("qr_signature")
  status        TicketStatus @default(ISSUED)
  issuedAt      DateTime     @default(now()) @map("issued_at")
  checkedInAt   DateTime?    @map("checked_in_at")
  checkedInById String?      @map("checked_in_by") @db.Uuid
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @default(now()) @updatedAt @map("updated_at")

  order         Order                @relation(fields: [orderId], references: [id], onDelete: Restrict)
  orderItem     OrderItem            @relation(fields: [orderItemId], references: [id], onDelete: Restrict)
  user          User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  concert       Concert              @relation(fields: [concertId], references: [id], onDelete: Restrict)
  ticketType    TicketType           @relation(fields: [ticketTypeId, concertId], references: [id, concertId], onDelete: Restrict)
  seatZone      SeatZone             @relation(fields: [seatZoneId, concertId], references: [id, concertId], onDelete: Restrict)
  checkedInBy   User?                @relation("TicketCheckedInBy", fields: [checkedInById], references: [id], onDelete: SetNull)
  checkinLogs   CheckinLog[]
  notifications Notification[]
  offlineItems  OfflineCheckinItem[]

  @@index([orderId])
  @@index([orderItemId])
  @@index([userId, concertId, status])
  @@index([userId, ticketTypeId, status])
  @@index([ticketTypeId, status])
  @@index([seatZoneId])
  @@index([checkedInAt])
  @@map("tickets")
}

model CheckinDevice {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deviceCode String       @unique @map("device_code") @db.VarChar(100)
  staffId    String       @map("staff_id") @db.Uuid
  concertId  String       @map("concert_id") @db.Uuid
  gateId     String       @map("gate_id") @db.Uuid
  name       String?      @db.VarChar(255)
  status     DeviceStatus @default(ACTIVE)
  lastSeenAt DateTime?    @map("last_seen_at")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @default(now()) @updatedAt @map("updated_at")

  staff          User                  @relation("DeviceStaff", fields: [staffId], references: [id], onDelete: Restrict)
  concert        Concert               @relation(fields: [concertId], references: [id], onDelete: Cascade)
  gate           CheckinGate           @relation(fields: [gateId, concertId], references: [id, concertId], onDelete: Restrict)
  checkinLogs    CheckinLog[]
  offlineBatches OfflineCheckinBatch[]

  @@index([staffId, status])
  @@index([concertId, gateId, status])
  @@map("checkin_devices")
}

model CheckinLog {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId      String?       @map("ticket_id") @db.Uuid
  guestId       String?       @map("guest_id") @db.Uuid
  concertId     String        @map("concert_id") @db.Uuid
  seatZoneId    String?       @map("seat_zone_id") @db.Uuid
  gateId        String?       @map("gate_id") @db.Uuid
  deviceId      String?       @map("device_id") @db.Uuid
  staffId       String?       @map("staff_id") @db.Uuid
  scanTokenHash String?       @map("scan_token_hash") @db.VarChar(255)
  result        CheckinResult
  reason        String?
  scannedAt     DateTime      @default(now()) @map("scanned_at")
  metadata      Json?         @db.JsonB
  createdAt     DateTime      @default(now()) @map("created_at")

  ticket   Ticket?        @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  guest    GuestList?     @relation(fields: [guestId], references: [id], onDelete: SetNull)
  concert  Concert        @relation(fields: [concertId], references: [id], onDelete: Cascade)
  seatZone SeatZone?      @relation(fields: [seatZoneId, concertId], references: [id, concertId], onDelete: Restrict)
  gate     CheckinGate?   @relation(fields: [gateId, concertId], references: [id, concertId], onDelete: Restrict)
  device   CheckinDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  staff    User?          @relation("CheckinStaff", fields: [staffId], references: [id], onDelete: SetNull)

  @@index([ticketId, scannedAt])
  @@index([concertId, scannedAt])
  @@index([gateId, scannedAt])
  @@index([deviceId, scannedAt])
  @@index([guestId, scannedAt])
  @@map("checkin_logs")
}

model OfflineCheckinBatch {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  batchToken    String             @unique @map("batch_token") @db.VarChar(128)
  deviceId      String             @map("device_id") @db.Uuid
  staffId       String             @map("staff_id") @db.Uuid
  concertId     String             @map("concert_id") @db.Uuid
  gateId        String             @map("gate_id") @db.Uuid
  status        OfflineBatchStatus @default(PENDING)
  itemCount     Int                @default(0) @map("item_count")
  acceptedCount Int                @default(0) @map("accepted_count")
  conflictCount Int                @default(0) @map("conflict_count")
  syncedAt      DateTime?          @map("synced_at")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @default(now()) @updatedAt @map("updated_at")

  device  CheckinDevice        @relation(fields: [deviceId], references: [id], onDelete: Restrict)
  staff   User                 @relation("OfflineBatchStaff", fields: [staffId], references: [id], onDelete: Restrict)
  concert Concert              @relation(fields: [concertId], references: [id], onDelete: Cascade)
  gate    CheckinGate          @relation(fields: [gateId, concertId], references: [id, concertId], onDelete: Restrict)
  items   OfflineCheckinItem[]

  @@index([concertId, status])
  @@index([deviceId, status])
  @@index([gateId, status])
  @@map("offline_checkin_batches")
}

model OfflineCheckinItem {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  batchId      String            @map("batch_id") @db.Uuid
  ticketId     String?           @map("ticket_id") @db.Uuid
  guestId      String?           @map("guest_id") @db.Uuid
  qrTokenHash  String?           @map("qr_token_hash") @db.VarChar(255)
  gateId       String?           @map("gate_id") @db.Uuid
  seatZoneId   String?           @map("seat_zone_id") @db.Uuid
  result       OfflineItemStatus @default(PENDING)
  errorCode    String?           @map("error_code") @db.VarChar(100)
  errorMessage String?           @map("error_message")
  scannedAt    DateTime          @map("scanned_at")
  syncedAt     DateTime?         @map("synced_at")
  metadata     Json?             @db.JsonB
  createdAt    DateTime          @default(now()) @map("created_at")

  batch    OfflineCheckinBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  ticket   Ticket?             @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  guest    GuestList?          @relation(fields: [guestId], references: [id], onDelete: SetNull)
  gate     CheckinGate?        @relation(fields: [gateId], references: [id], onDelete: SetNull)
  seatZone SeatZone?           @relation(fields: [seatZoneId], references: [id], onDelete: SetNull)

  @@unique([batchId, qrTokenHash])
  @@index([batchId, result])
  @@index([ticketId])
  @@index([guestId])
  @@index([gateId, result])
  @@map("offline_checkin_items")
}

model GuestImportJob {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  concertId    String       @map("concert_id") @db.Uuid
  uploadedById String       @map("uploaded_by") @db.Uuid
  fileUrl      String       @map("file_url")
  status       ImportStatus @default(PENDING)
  totalRows    Int          @default(0) @map("total_rows")
  successRows  Int          @default(0) @map("success_rows")
  errorRows    Int          @default(0) @map("error_rows")
  startedAt    DateTime?    @map("started_at")
  completedAt  DateTime?    @map("completed_at")
  errorMessage String?      @map("error_message")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @default(now()) @updatedAt @map("updated_at")

  concert    Concert            @relation(fields: [concertId], references: [id], onDelete: Cascade)
  uploadedBy User               @relation("GuestImportCreator", fields: [uploadedById], references: [id], onDelete: Restrict)
  guests     GuestList[]
  errors     GuestImportError[]

  @@index([concertId, status])
  @@map("guest_import_jobs")
}

model GuestList {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  concertId     String      @map("concert_id") @db.Uuid
  seatZoneId    String?     @map("seat_zone_id") @db.Uuid
  importJobId   String?     @map("import_job_id") @db.Uuid
  fullName      String      @map("full_name") @db.VarChar(255)
  phone         String      @db.VarChar(20)
  email         String?     @db.VarChar(255)
  code          String?     @db.VarChar(100)
  status        GuestStatus @default(INVITED)
  checkedInAt   DateTime?   @map("checked_in_at")
  checkedInById String?     @map("checked_in_by") @db.Uuid
  note          String?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @default(now()) @updatedAt @map("updated_at")

  concert      Concert              @relation(fields: [concertId], references: [id], onDelete: Cascade)
  seatZone     SeatZone?            @relation(fields: [seatZoneId, concertId], references: [id, concertId], onDelete: Restrict)
  importJob    GuestImportJob?      @relation(fields: [importJobId], references: [id], onDelete: SetNull)
  checkedInBy  User?                @relation("GuestCheckedInBy", fields: [checkedInById], references: [id], onDelete: SetNull)
  checkinLogs  CheckinLog[]
  offlineItems OfflineCheckinItem[]

  @@unique([concertId, phone])
  @@unique([concertId, code])
  @@index([concertId, status])
  @@index([phone])
  @@index([seatZoneId])
  @@map("guest_list")
}

model GuestImportError {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobId        String   @map("job_id") @db.Uuid
  rowNumber    Int      @map("row_number")
  rawData      Json?    @map("raw_data") @db.JsonB
  errorCode    String   @map("error_code") @db.VarChar(100)
  errorMessage String   @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at")

  job GuestImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, rowNumber, errorCode])
  @@index([jobId])
  @@map("guest_import_errors")
}

model ArtistBioJob {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  concertId     String             @map("concert_id") @db.Uuid
  requestedById String?            @map("requested_by") @db.Uuid
  status        ArtistBioJobStatus @default(PENDING)
  sourceFileUrl String             @map("source_file_url")
  extractedText String?            @map("extracted_text")
  generatedBio  String?            @map("generated_bio")
  errorMessage  String?            @map("error_message")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @default(now()) @updatedAt @map("updated_at")

  concert     Concert @relation(fields: [concertId], references: [id], onDelete: Cascade)
  requestedBy User?   @relation("ArtistBioRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)

  @@index([concertId, status])
  @@index([status, createdAt])
  @@map("artist_bio_jobs")
}

model Notification {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String?             @map("user_id") @db.Uuid
  concertId    String?             @map("concert_id") @db.Uuid
  ticketId     String?             @map("ticket_id") @db.Uuid
  channel      NotificationChannel
  type         NotificationType
  status       NotificationStatus  @default(PENDING)
  payload      Json                @db.JsonB
  attempts     Int                 @default(0)
  errorMessage String?             @map("error_message")
  sentAt       DateTime?           @map("sent_at")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @default(now()) @updatedAt @map("updated_at")

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  concert Concert? @relation(fields: [concertId], references: [id], onDelete: Cascade)
  ticket  Ticket?  @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@index([concertId, status])
  @@index([ticketId])
  @@map("notifications")
}

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String   @db.VarChar(100)
  entityType  String   @map("entity_type") @db.VarChar(100)
  entityId    String?  @map("entity_id") @db.VarChar(100)
  metadata    Json?    @db.JsonB
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("audit_logs")
}
