# ============================================================================
# TicketBox — biến môi trường DÙNG CHUNG cho toàn bộ monorepo.
# Copy file này thành `.env` (cùng thư mục ticket-box-app/) rồi điền giá trị.
# Tất cả app / worker / test / prisma đọc từ DUY NHẤT file .env này.
# ============================================================================

NODE_ENV=development
PORT=3000
WEB_URL=http://localhost:3001
VITE_API_BASE_URL=http://localhost:3000/v1

# ── Database (PostgreSQL) ───────────────────────────────────────────────────
DATABASE_URL=postgresql://ticketbox:ticketbox@localhost:5433/ticketbox?schema=public
# Compose API containers dùng hai biến này. Bỏ trống sẽ dùng postgres/redis
# service nội bộ; đặt URL bên ngoài nếu muốn dùng Neon/Upstash.
# API_DATABASE_URL=postgresql://user:password@host/database?sslmode=require
# API_REDIS_URL=rediss://user:password@host:6379

# ── Auth (JWT) ──────────────────────────────────────────────────────────────
JWT_SECRET=ticketbox-local-access-secret
JWT_REFRESH_SECRET=ticketbox-local-refresh-secret

# ── Redis (BullMQ / cache) ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ── SMTP (worker gửi email OTP, nhắc lịch, ...) ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# SMTP_FROM=TicketBox <noreply@ticketbox.vn>

# ── Load test / Orders: chính sách giữ chỗ ──────────────────────────────────
# ORDER_HOLD_DURATION_SECONDS=900
# Chỉ bật trong môi trường load test order/catalog. Danh sách là IP nguồn kết nối
# trực tiếp tới API, phân tách bằng dấu phẩy; không đọc X-Forwarded-For do client
# tự gửi.
ORDER_RATE_LIMIT_WHITELIST_ENABLED=false
ORDER_RATE_LIMIT_WHITELIST=127.0.0.1,::1

# ── Worker: job expire-holds ────────────────────────────────────────────────
# EXPIRE_HOLDS_INTERVAL_MS=60000
# EXPIRE_HOLDS_BATCH_SIZE=50
# EXPIRE_HOLDS_DRY_RUN=false

# ── Storage (local stub) ────────────────────────────────────────────────────
# STORAGE_PUBLIC_BASE_URL=http://localhost:9000
# STORAGE_LOCAL_ROOT=
# STORAGE_PRESS_KIT_ROOT=
# STORAGE_IMPORT_ROOT=

# ── AI Artist Bio (mặc định Groq — OpenAI-compatible, free, KHÔNG cần thẻ) ───
# Lấy key tại console.groq.com (email/Google). Đổi provider chỉ bằng 3 biến này.
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=
AI_MODEL=llama-3.3-70b-versatile
# AI_MAX_SOURCE_CHARS=8000        # ngân sách input (ký tự), chia đều cho concert + từng nghệ sĩ
# AI_TOKENS_PER_SECTION=500       # suất output cho MỖI phần (concert_bio / 1 nghệ sĩ, bio ≤ 250 từ)
# AI_MAX_OUTPUT_TOKENS=6000       # TRẦN CỨNG cho max_tokens (không còn là giá trị cố định)
# Ollama (free vĩnh viễn, offline): AI_BASE_URL=http://localhost:11434/v1  AI_MODEL=qwen2.5  AI_API_KEY=ollama
# OpenRouter: AI_BASE_URL=https://openrouter.ai/api/v1  AI_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Supabase Storage (PDF press kit + ảnh nghệ sĩ) ──────────────────────────
# Bucket press kit để Private, bucket ảnh để Public. Service-role key chỉ ở backend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PRESS_KIT_BUCKET=press-kits
SUPABASE_ARTIST_IMAGE_BUCKET=artist-images

# ── Guest List CSV import (Google Drive) ────────────────────────────────────
# Service account (bật Drive API, được share Viewer thư mục concert). Base64 của JSON key.
# Tạo base64:  base64 -w0 service-account.json   (hoặc dán JSON thô cũng được)
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── QR ký vé (Ed25519, base64 của PEM) ──────────────────────────────────────
# Private key ký QR (api-server); public key verify (đặt được ở máy checker).
# Bỏ trống sẽ dùng cặp khóa dev mặc định trong config/env.ts. PROD phải override.
# Tạo cặp mới:
#   node -e "const{generateKeyPairSync}=require('node:crypto');const{publicKey,privateKey}=generateKeyPairSync('ed25519');console.log('QR_SIGNING_PRIVATE_KEY_B64='+Buffer.from(privateKey.export({type:'pkcs8',format:'pem'})).toString('base64'));console.log('QR_SIGNING_PUBLIC_KEY_B64='+Buffer.from(publicKey.export({type:'spki',format:'pem'})).toString('base64'))"
QR_SIGNING_PRIVATE_KEY_B64=
QR_SIGNING_PUBLIC_KEY_B64=

# ── VNPAY ───────────────────────────────────────────────────────────────────
VNPAY_TMN_CODE=TICKETBOX
VNPAY_HASH_SECRET=ticketbox_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_QUERYDR_URL=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction
VNPAY_RETURN_URL=http://localhost:3000/v1/payment/return
# VNPAY_CB_FAILURE_THRESHOLD=5
# VNPAY_CB_ERROR_THRESHOLD=50
# VNPAY_CB_RESET_TIMEOUT=30000
# VNPAY_BULKHEAD_LIMIT=20

# ── MoMo ────────────────────────────────────────────────────────────────────
MOMO_PARTNER_CODE=TICKETBOX
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_REDIRECT_URL=http://localhost:3000/v1/payment/return/momo
MOMO_IPN_URL=http://localhost:3000/v1/payments/webhooks/momo
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_QUERY_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/query
# Legacy alias used by config/payment.ts if that helper is imported elsewhere.
MOMO_QUERY_URL=https://test-payment.momo.vn/v2/gateway/api/query
# MOMO_CB_FAILURE_THRESHOLD=5
# MOMO_CB_ERROR_THRESHOLD=50
# MOMO_CB_RESET_TIMEOUT=30000
# MOMO_BULKHEAD_LIMIT=20

# ── Payment mock servers ────────────────────────────────────────────────────
MOMO_MOCK_PORT=4101
VNPAY_MOCK_PORT=4102
# Chỉ bật khi VNPAY_URL trỏ tới payment mock local; để trống khi dùng sandbox thật.
# VNPAY_MOCK_PREPARE_URL=http://localhost:4102/vnpay/prepare
