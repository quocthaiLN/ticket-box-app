# URL nhìn từ container k6 tới API chạy trên máy host.
BASE_URL=http://host.docker.internal:3000/v1

# Tổng request tạo order và số user/token được chuẩn bị trong setup.
TOTAL_REQUESTS=1000
USER_COUNT=1000
USER_START=1

# Số virtual user gửi order đồng thời.
VUS=100

# Số loại vé khác nhau tối đa trong một order (không phải tổng quantity).
# Test random cart có từ 1 đến giá trị này; hiện hỗ trợ tối đa 3.
MAX_CART_ITEMS=3

# Cùng RUN_SEED sẽ tạo lại cùng concert, ticket type và quantity theo iteration.
RUN_SEED=20260707

# Mật khẩu chung của các load-test user được tạo bởi db:seed.
LOAD_TEST_PASSWORD=Password@123
