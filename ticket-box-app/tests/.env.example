# URL nhìn từ container k6 tới API chạy trên máy host.
BASE_URL=http://host.docker.internal:3000/v1

# URL nhìn từ container k6 tới MoMo mock.
MOMO_MOCK_CONTROL_URL=http://host.docker.internal:4101

# Cấu hình chung cho order test.
TOTAL_REQUESTS=1000
USER_COUNT=1000
USER_START=1
VUS=100
MAX_CART_ITEMS=3
RUN_SEED=20260707
LOAD_TEST_PASSWORD=Password@123

# Cấu hình cho payment bulkhead test.
PAYMENT_BULKHEAD_LIMIT=20
PAYMENT_BULKHEAD_VUS=35
PAYMENT_BULKHEAD_LATENCY_MS=5000
PAYMENT_BULKHEAD_TIMEOUT_MS=10000
PAYMENT_BULKHEAD_CONCERT_ID=00000000-0000-0000-0000-000000000202
PAYMENT_BULKHEAD_TICKET_TYPE_ID=00000000-0000-0000-0000-000000000510

# Cấu hình cho payment circuit breaker test.
PAYMENT_CIRCUIT_TOTAL_ITERATIONS=15
PAYMENT_CIRCUIT_FAILURE_THRESHOLD=2
PAYMENT_CIRCUIT_COOLDOWN_SECONDS=6
PAYMENT_CIRCUIT_FAIL_MODE=fail
PAYMENT_CIRCUIT_RECOVERY_MODE=ok
PAYMENT_CIRCUIT_CONCERT_ID=00000000-0000-0000-0000-000000000202
PAYMENT_CIRCUIT_TICKET_TYPE_ID=00000000-0000-0000-0000-000000000510
